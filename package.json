    "@types/jest": "^29.5.12",
    "@types/node": "^18.18.26",
    "@types/react": "^19.0.48",
    "@types/react-dom": "^19.0.18",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-scripts": "^5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
